{
  "buildCommand": "cd client && npm run build",
  "installCommand": "cd server && npm install && npx prisma generate && cd ../client && npm install",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/src/**,server/prisma/**",
      "maxDuration": 10
    }
  }
}
