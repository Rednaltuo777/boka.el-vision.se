generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?
  forcePasswordChange Boolean @default(false)
  resetPasswordTokenHash String? @unique
  resetPasswordExpiresAt DateTime?
  name        String?
  company     String?
  logoUrl     String?
  department  String?
  phone       String?
  role        String   @default("client") // "superadmin" | "admin" | "client"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitations  Invitation[]
  bookings     Booking[]     @relation("BookingClient")
  blockingPeriods BlockingPeriod[]
  chatMessages ChatMessage[]
  chatReads    BookingChatRead[]
  bookingChanges BookingChange[]
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  invitedBy   User   @relation(fields: [invitedById], references: [id])
  invitedById String
}

model Course {
  id       String    @id @default(uuid())
  name     String    @unique
  isCustom Boolean   @default(false)
  bookings Booking[]
}

model Booking {
  id            String   @id @default(uuid())
  date          DateTime
  endDate       DateTime?
  city          String
  participants  Int      @default(1)
  rescheduleToken Boolean @default(true)
  isPrivate     Boolean  @default(false)
  sharedNotes   String   @default("")
  privateNotes  String   @default("")
  customCourse  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client   User   @relation("BookingClient", fields: [clientId], references: [id])
  clientId String

  course   Course @relation(fields: [courseId], references: [id])
  courseId String

  chatMessages   ChatMessage[]
  chatReads      BookingChatRead[]
  changes        BookingChange[]
  outlookEventId String?
}

model BookingChange {
  id         String   @id @default(uuid())
  changeType String
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  changedBy   User   @relation(fields: [changedById], references: [id], onDelete: Cascade)
  changedById String
}

model BlockingPeriod {
  id        String   @id @default(uuid())
  startDate DateTime
  endDate   DateTime
  type      String
  customLabel String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String
}

model BookingChatRead {
  id         String   @id @default(uuid())
  lastReadAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([bookingId, userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String
}

model OAuthToken {
  id           String   @id @default(uuid())
  provider     String   @default("microsoft") // "microsoft"
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
