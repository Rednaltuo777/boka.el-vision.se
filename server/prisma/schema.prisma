generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String?
  name        String?
  company     String?
  department  String?
  phone       String?
  role        String   @default("client") // "admin" | "client"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitations  Invitation[]
  bookings     Booking[]     @relation("BookingClient")
  chatMessages ChatMessage[]
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  invitedBy   User   @relation(fields: [invitedById], references: [id])
  invitedById String
}

model Course {
  id       String    @id @default(uuid())
  name     String    @unique
  isCustom Boolean   @default(false)
  bookings Booking[]
}

model Booking {
  id            String   @id @default(uuid())
  date          DateTime
  endDate       DateTime?
  city          String
  sharedNotes   String   @default("")
  privateNotes  String   @default("")
  customCourse  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client   User   @relation("BookingClient", fields: [clientId], references: [id])
  clientId String

  course   Course @relation(fields: [courseId], references: [id])
  courseId String

  chatMessages   ChatMessage[]
  outlookEventId String?
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String

  author   User   @relation(fields: [authorId], references: [id])
  authorId String
}

model OAuthToken {
  id           String   @id @default(uuid())
  provider     String   @default("microsoft") // "microsoft"
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
